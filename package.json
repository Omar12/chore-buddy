{
  "name": "chore-buddy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f app",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:rebuild": "docker-compose -f docker-compose.dev.yml up -d --build",
    "docker:prod": "docker-compose up -d",
    "docker:prod:logs": "docker-compose logs -f app",
    "docker:prod:down": "docker-compose down",
    "docker:prod:rebuild": "docker-compose up -d --build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^15.0.3",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.8.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
