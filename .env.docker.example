# Database Configuration
# For Docker, the database file is stored in the persistent volume at /app/data
DATABASE_URL="file:/app/data/chore-buddy.db"

# Authentication Secret
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-here"

# App Configuration
# Set this to your production URL or leave as localhost for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Configuration (Optional - for notifications)
EMAIL_FROM=noreply@chorebuddy.com
EMAIL_SERVICE_API_KEY=your-email-service-api-key
